# ============================================================================
EXO_APP_ID=your-azure-ad-app-client-id
EXO_ORG=bindergroesswang.at
EXO_CERTIFICATE_THUMBPRINT=your-certificate-thumbprint

# ============================================================================
# Active Directory & Profile Folder
# ============================================================================
PROFILE_BASE_PATH=\\bgr\dfs\Profile
DEFAULT_PASSWORD=Onboarding13IT!
REMOTE_ROUTING_DOMAIN=bindergroesswang-at.mail.onmicrosoft.com

# ============================================================================
# AAD Connect Sync / Calendar Permissions
# ============================================================================
# Seconds to wait for AAD Connect sync before first calendar permissions attempt
AAD_SYNC_WAIT=300
# Number of retry attempts for calendar permissions
CALENDAR_RETRY_ATTEMPTS=6
# Seconds between retries
CALENDAR_RETRY_INTERVAL=300

# ============================================================================
# Dry Run Mode (true = preview only, false = production)
# ============================================================================
DRY_RUN=true
